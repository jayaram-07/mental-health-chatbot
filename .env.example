# Google Cloud service-account key (the entire JSON, as a single-line string).
# Needs Vertex AI (aiplatform.user) + Cloud Text-to-Speech access.
# Set this in Vercel as an environment variable — never commit the real value.
GCP_SA_KEY={"type":"service_account","project_id":"...","private_key":"...","client_email":"..."}

# GCP project id that hosts Vertex AI + Text-to-Speech.
GCP_PROJECT=your-gcp-project-id

# Vertex AI region for the Gemini model.
GCP_LOCATION=us-central1

# Gemini model id. gemini-2.5-flash is a thinking model — see api/_persona.ts.
GEMINI_MODEL=gemini-2.5-flash
